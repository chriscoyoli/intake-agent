# ---- Copy this file to .env and fill in what you use ----
# Nothing here is needed to try the CLI in-memory: `python cli.py` runs with zero creds.

# ---- The agent brain ----
# Omit this to run the deterministic scripted fallback instead of live Claude.
ANTHROPIC_API_KEY=sk-ant-...
# INTAKE_MODEL=claude-sonnet-4-6

# ---- Slack (required only for the real Slack bot, app.py) ----
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# ---- Routing: which destination each team writes to ----
# Options per team: sheet | airtable | asana | jira | stub
# Omit a team to use DEFAULT_DESTINATION. Start everything on the Sheet:
DEFAULT_DESTINATION=sheet
# Then flip individual teams to their real tool as you wire them up, e.g.:
# INTAKE_ROUTES=legal=sheet,it=jira,marketing=asana,product=sheet

# ---- Google Sheets (default destination) ----
GOOGLE_SERVICE_ACCOUNT_FILE=./service_account.json
GOOGLE_SHEET_ID=1AbC...the-id-from-the-sheet-url
GOOGLE_WORKSHEET=Requests

# ---- Airtable (optional) ----
# AIRTABLE_TOKEN=pat...
# AIRTABLE_BASE_ID=app...
# AIRTABLE_TABLE=Requests

# ---- Asana (optional) ----
# ASANA_TOKEN=1/...
# ASANA_PROJECT_ID=1200000000000000

# ---- Jira Cloud (optional) ----
# JIRA_BASE_URL=https://yourcompany.atlassian.net
# JIRA_EMAIL=you@yourcompany.com
# JIRA_API_TOKEN=...
# JIRA_PROJECT_KEY=IT
# JIRA_ISSUE_TYPE=Task
